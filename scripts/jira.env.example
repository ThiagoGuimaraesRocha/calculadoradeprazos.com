# Copie para variáveis de ambiente do usuário ou defina antes de rodar os scripts em scripts/:
#   jira-list-projects.ps1           — lista projetos
#   jira-list-issues.ps1             — lista cartões (JQL padrão: project = CALC)
#   jira-create-issue.ps1            — cria um cartão
#   jira-create-reestilizacao-issues.ps1 — cria lote (data/jira-reestilizacao-issues.json)
#   jira-sync-reestilizacao-from-json.ps1 — atualiza CALC-7..13 a partir do JSON
#   jira-update-issue.ps1            — atualiza issue existente
# PowerShell (sessão atual):
#   $env:JIRA_BASE_URL = "https://SUAORG.atlassian.net"
#   $env:JIRA_EMAIL = "voce@exemplo.com"
#   $env:JIRA_API_TOKEN = "(token em https://id.atlassian.com/manage-profile/security/api-tokens)"

JIRA_BASE_URL=https://SUAORG.atlassian.net
JIRA_EMAIL=voce@exemplo.com
JIRA_API_TOKEN=
